@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Detalle del Curso";
}

<h2>@Model.Nombre</h2>

<div class="card p-4">
    <p><strong>Código:</strong> @Model.Codigo</p>
    <p><strong>Créditos:</strong> @Model.Creditos</p>
    <p><strong>Cupo máximo:</strong> @Model.CupoMaximo</p>
    <p><strong>Horario:</strong> @Model.HorarioInicio.ToString(@"hh\:mm") - @Model.HorarioFin.ToString(@"hh\:mm")</p>
    <p><strong>Estado:</strong> @(Model.Activo ? "Activo" : "Inactivo")</p>

    <a asp-controller="Matriculas" asp-action="Inscribirse" asp-route-id="@Model.Id" class="btn btn-success mt-3">
        Inscribirse
    </a>
    <a asp-action="Index" class="btn btn-secondary mt-3">Volver al catálogo</a>
</div>