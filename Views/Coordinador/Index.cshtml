@model IEnumerable<PortalAcademico.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador";
}

<h2>Panel de Coordinador</h2>

<a asp-action="Crear" class="btn btn-success mb-3">+ Nuevo Curso</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupo</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.Codigo</td>
                <td>@curso.Nombre</td>
                <td>@curso.Creditos</td>
                <td>@curso.CupoMaximo</td>
                <td>@(curso.Activo ? "Activo" : "Inactivo")</td>
                <td>
                    <a asp-action="Editar" asp-route-id="@curso.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Matriculas" asp-route-id="@curso.Id" class="btn btn-info btn-sm">Matrículas</a>
                    @if (curso.Activo)
                    {
                        <a asp-action="Desactivar" asp-route-id="@curso.Id" class="btn btn-danger btn-sm">Desactivar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>