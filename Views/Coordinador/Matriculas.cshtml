@model IEnumerable<PortalAcademico.Models.Matricula>

@{
    ViewData["Title"] = "Matrículas";
}

<h2>Matrículas - @ViewBag.Curso.Nombre</h2>

<a asp-action="Index" class="btn btn-secondary mb-3">Volver al panel</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var matricula in Model)
        {
            <tr>
                <td>@matricula.UsuarioId</td>
                <td>@matricula.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@matricula.Estado</td>
                <td>
                    @if (matricula.Estado == PortalAcademico.Models.EstadoMatricula.Pendiente)
                    {
                        <a asp-action="Confirmar" asp-route-id="@matricula.Id" class="btn btn-success btn-sm">Confirmar</a>
                        <a asp-action="Cancelar" asp-route-id="@matricula.Id" class="btn btn-danger btn-sm">Cancelar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>