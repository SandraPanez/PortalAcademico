@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Crear Curso";
}

<h2>Crear Curso</h2>

<form method="post" asp-action="Crear">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label>Código</label>
        <input asp-for="Codigo" class="form-control" />
        <span asp-validation-for="Codigo" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Créditos</label>
        <input asp-for="Creditos" class="form-control" type="number" min="1" />
        <span asp-validation-for="Creditos" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label>Cupo Máximo</label>
        <input asp-for="CupoMaximo" class="form-control" type="number" min="1" />
    </div>
    <div class="mb-3">
        <label>Horario Inicio</label>
        <input asp-for="HorarioInicio" class="form-control" type="time" />
    </div>
    <div class="mb-3">
        <label>Horario Fin</label>
        <input asp-for="HorarioFin" class="form-control" type="time" />
    </div>
    <div class="mb-3">
        <label>Activo</label>
        <input asp-for="Activo" class="form-check-input" type="checkbox" />
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>