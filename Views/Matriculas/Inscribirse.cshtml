@model PortalAcademico.Models.Curso

@{
    ViewData["Title"] = "Inscribirse al Curso";
}

<h2>Inscribirse en @Model.Nombre</h2>

<div class="card p-4">
    <p><strong>Código:</strong> @Model.Codigo</p>
    <p><strong>Créditos:</strong> @Model.Creditos</p>
    <p><strong>Cupo máximo:</strong> @Model.CupoMaximo</p>
    <p><strong>Horario:</strong> @Model.HorarioInicio.ToString(@"hh\:mm") - @Model.HorarioFin.ToString(@"hh\:mm")</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (ViewBag.Exito != null)
    {
        <div class="alert alert-success">@ViewBag.Exito</div>
    }

    @if (ViewBag.Exito == null)
    {
        <form method="post" asp-action="Inscribirse" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Confirmar inscripción</button>
            <a asp-controller="Cursos" asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
        </form>
    }
</div>